{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glean",
  "version": "0.1.0",
  "identifier": "com.glean.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Glean",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity"
  },
  "plugins": {
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "",
      "endpoints": []
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glean",
  "version": "0.1.0",
  "identifier": "com.glean.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Glean",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first AI file manager",
    "longDescription": "Glean is a local-first, AI-native macOS file manager. Smart indexing, semantic search, agent tools, all data stays on your device.",
    "publisher": "Glean",
    "copyright": "MIT © 2026 Glean Authors",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyNjM4NERGM0IwQzlCNDYKUldSR213dzczNFJqa3FvNjk1SGpZb1ZpQ3FsUEYyT3dnYWc0ZDVxeEh4ZWsvazBwZDFrVTVlazYK",
      "endpoints": [
        "https://github.com/WalkAlone0325/glean/releases/latest/download/latest.json"
      ]
    }
  }
}
